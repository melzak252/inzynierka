    "def prob_to_odds(prob, margin=0.00):\n",
    "    adj_prob1 = prob * (1 + margin)\n",
    "    adj_prob2 = (1 - prob) * (1 + margin)\n",
    "    odds1 = 1 / adj_prob1\n",
    "    return odds1, 1 / adj_prob2\n",
    "\n",
    "prob_to_odds(0.6)\n",
    "\n"
   ]
