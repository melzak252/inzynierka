   "source": [
    "# Calc ECE for each bookie\n",
    "def expected_calibration_error(y_true, y_prob, n_bins=10):\n",
    "    prob_true, prob_pred = calibration_curve(y_true, y_prob, n_bins=n_bins)\n",
    "    ece = sum(abs(prob_true[i] - prob_pred[i]) * (sum((y_prob >= i/n_bins) & (y_prob < (i+1)/n_bins)) / len(y_prob)) for i in range(n_bins))\n",
    "    return ece\n",
    "for bookie in bookies:\n",
    "    odds1 = df[f\"odds1_{bookie}_close\"].dropna()\n",
    "    odds2 = df[f\"odds2_{bookie}_close\"].dropna()\n",
    "    y_true = df.loc[odds1.index, \"t1_win\"].astype(int)\n",
    "    probs1, probs2 = odds_to_prob(odds1, odds2)\n",
    "    ece = expected_calibration_error(y_true, probs1)\n",
    "    print(f\"{bookie} close - ECE: {ece:.4f}\")"
   ]
  },
