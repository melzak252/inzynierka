   "source": [
    "def odds_to_prob(odds1, odds2):\n",
    "    # adjust margin\n",
    "    margin = 1 / odds1 + 1 / odds2\n",
    "    \n",
    "    adj_odds1 = odds1 * margin\n",
    "    adj_odds2 = odds2 * margin\n",
    "    return 1/adj_odds1, 1/adj_odds2\n",
    "\n",
    "odds_to_prob(1.9, 1.9)"
   ]
  },
