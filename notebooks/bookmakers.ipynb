    "bankroll = 1000\n",
    "arb_bankroll = 1000\n",
    "kelly_bankroll = 1000\n",
    "bets = []\n",
    "kelly_bets = []\n",
    "for i, match in test_df.iterrows():\n",
    "    date = match[\"odds_date\"]\n",
    "    odds1 = match.avg_odds_home\n",
    "    odds2 = match.avg_odds_away\n",
    "    true_prob1, true_prob2 = odds_to_prob(odds1, odds2)    \n",
    "    max_odds1 = 0\n",
    "    max_odds2 = 0\n",
    "    sum_odds1 = 0\n",
    "    sum_odds2 = 0\n",
    "    sum_prob1 = 0\n",
    "    sum_prob2 = 0\n",
    "    count = 0\n",
    "    for bookie in bookies:\n",
    "        # odds1_bookie_close = match[f\"odds1_{bookie}_close\"]\n",
    "        # odds2_bookie_close = match[f\"odds2_{bookie}_close\"]\n",
    "        odds1_bookie_open = match[f\"odds1_{bookie}_open\"]\n",
    "        odds2_bookie_open = match[f\"odds2_{bookie}_open\"]\n",
    "        # avg of open and close odds for bookie\n",
    "        # odds1_bookie = (odds1_bookie_close + odds1_bookie_open) / 2 if pd.notnull(odds1_bookie_close) and pd.notnull(odds1_bookie_open) else odds1_bookie_close if pd.notnull(odds1_bookie_close) else odds1_bookie_open\n",
    "        # odds2_bookie = (odds2_bookie_close + odds2_bookie_open) / 2 if pd.notnull(odds2_bookie_close) and pd.notnull(odds2_bookie_open) else odds2_bookie_close if pd.notnull(odds2_bookie_close) else odds2_bookie_open\n",
    "        odds1_bookie = odds1_bookie_open\n",
    "        odds2_bookie = odds2_bookie_open\n",
    "        if pd.notnull(odds1_bookie) and pd.notnull(odds2_bookie):\n",
    "            if odds1_bookie > max_odds1:\n",
    "                max_odds1 = odds1_bookie\n",
    "            if odds2_bookie > max_odds2:\n",
    "                max_odds2 = odds2_bookie\n",
    "\n",
    "            prob1, prob2 = odds_to_prob(odds1_bookie, odds2_bookie)\n",
    "            sum_odds1 += odds1_bookie\n",
    "            sum_odds2 += odds2_bookie\n",
    "            sum_prob1 += prob1\n",
    "            sum_prob2 += prob2\n",
    "            count += 1\n",
    "            \n",
    "    # true_prob1, true_prob2 = odds_to_prob(sum_odds1 / count, sum_odds2 / count)\n",
    "    true_prob1, true_prob2 = sum_prob1/count, sum_prob2/count\n",
    "    win = 1 if match.t1_win else 0\n",
    "    arbitrage = ((1 / (max_odds1*(1-TAX_RATE))) + (1 / (max_odds2*(1-TAX_RATE))))\n",
    "    \n",
    "    if 0 < (1 - arbitrage) < 0.1:\n",
    "        kelly_bet_amount = kelly_bankroll * 0.1\n",
    "        # kelly_bet_amount = min(kelly_bet_amount, bankroll * kelly_cap)\n",
    "        kelly_team1_bet = kelly_bet_amount * (1 / max_odds1) / (1 / max_odds1 + 1 / max_odds2)\n",
    "        kelly_team2_bet = kelly_bet_amount - kelly_team1_bet\n",
    "\n",
    "        bet_amount = 100\n",
    "        team_1_bet = bet_amount * (1 / max_odds1) / (1 / max_odds1 + 1 / max_odds2)\n",
    "        team_2_bet = bet_amount - team_1_bet\n",
    "        win_amount = team_1_bet * max_odds1 * (1 - TAX_RATE) if win else team_2_bet * max_odds2 * (1 - TAX_RATE)\n",
    "        update = win_amount - bet_amount\n",
    "\n",
    "        kelly_win_amount = kelly_team1_bet * max_odds1 * (1 - TAX_RATE) if win else kelly_team2_bet * max_odds2 * (1 - TAX_RATE)\n",
    "        kelly_update = kelly_win_amount - kelly_bet_amount\n",
    "        kelly_bankroll += kelly_update\n",
    "\n",
    "        bankroll += update\n",
    "        bets.append({\n",
    "            \"match_id\": match.golgg_match_id,\n",
    "            \"date\": date,\n",
    "            \"bet_amount\": bet_amount,\n",
    "            \"bankroll\": bankroll,\n",
    "            \"update\": update\n",
    "        })\n",
    "        \n",
    "        kelly_bets.append({\n",
    "            \"match_id\": match.golgg_match_id,\n",
    "            \"date\": date,\n",
    "            \"bet_amount\": kelly_bet_amount,\n",
    "            \"bankroll\": kelly_bankroll,\n",
    "            \"update\": kelly_update\n",
    "        })\n",
    "\n",
    "        arb_opportunities.append({\n",
    "            \"match_id\": match.golgg_match_id,\n",
    "            \"date\": date,\n",
    "            \"max_odds1\": max_odds1,\n",
    "            \"max_odds2\": max_odds2,\n",
    "            \"arbitrage\": arbitrage,\n",
    "            \"arbitrage_value\": (1 - arbitrage) * 100,\n",
    "            \"bankroll\": bankroll,\n",
    "            \"update\": update\n",
    "        }) \n",
    "        continue\n",
    "    \n",
    "    EV = true_prob1 * (max_odds1 * (1 - TAX_RATE)) - 1\n",
    "    if EV > EV_THRESHOLD and max_odds1 > 1.2 and EV < 0.5:\n",
    "        kelly_bet_amount = kelly_bankroll * kelly_criterion(true_prob1, max_odds1 * (1 - TAX_RATE) - 1) * 0.75\n",
    "        kelly_bet_amount = min(kelly_bet_amount, kelly_cap)\n",
    "        kelly_update = kelly_bet_amount * (max_odds1 * (1 - TAX_RATE) - 1) if win else -kelly_bet_amount\n",
    "        kelly_bankroll += kelly_update\n",
    "        kelly_bets.append({\n",
    "            \"match_id\": match.golgg_match_id,\n",
    "            \"date\": date,\n",
    "            \"bet_amount\": kelly_bet_amount,\n",
    "            \"bankroll\": kelly_bankroll,\n",
    "            \"update\": kelly_update\n",
    "        })\n",
    "        bet_amount = 20\n",
    "        update = bet_amount * (max_odds1 * (1 - TAX_RATE) - 1) if win else -bet_amount\n",
    "        bankroll += update\n",
    "        bets.append({\n",
    "            \"match_id\": match.golgg_match_id,\n",
    "            \"date\": date,\n",
    "            \"bet_amount\": bet_amount,\n",
    "            \"bankroll\": bankroll,\n",
    "            \"update\": update\n",
    "        })\n",
    "        opportunities.append({\n",
    "            \"match_id\": match.golgg_match_id,\n",
    "            \"date\": date,\n",
    "            \"true_prob1\": true_prob1,\n",
    "            \"true_prob2\": true_prob2,\n",
    "            \"max_odds1\": max_odds1,\n",
    "            \"max_odds2\": max_odds2,\n",
    "            \"EV\": EV*100,\n",
    "            \"update\": update\n",
    "\n",
    "        })\n",
    "        \n",
    "        \n",
    "    evs.append(EV)\n",
    "        \n",
    "    win = 0 if win else 1\n",
    "    EV = true_prob2 * (max_odds2 * (1 - TAX_RATE)) - 1\n",
    "    if EV > EV_THRESHOLD and max_odds2 > 1.2 and EV < 0.5:\n",
    "        kelly_bet_amount = kelly_bankroll * kelly_criterion(true_prob2, max_odds2 * (1 - TAX_RATE) - 1) * 0.75\n",
    "\n",
    "        kelly_bet_amount = max(min(kelly_bet_amount, kelly_cap), 0)\n",
    "        \n",
    "        kelly_update = kelly_bet_amount * (max_odds2 * (1 - TAX_RATE) - 1) if win else -kelly_bet_amount\n",
    "        kelly_bankroll += kelly_update\n",
    "\n",
    "        bet_amount = 20\n",
    "        update = bet_amount * (max_odds2 * (1 - TAX_RATE) - 1) if win else -bet_amount\n",
    "        bankroll += update\n",
    "        bets.append({\n",
    "            \"match_id\": match.golgg_match_id,\n",
    "            \"date\": date,\n",
    "            \"bet_amount\": bet_amount,\n",
    "            \"bankroll\": bankroll,\n",
    "            \"update\": update\n",
    "        })\n",
    "\n",
    "        kelly_bets.append({\n",
    "            \"match_id\": match.golgg_match_id,\n",
    "            \"date\": date,\n",
    "            \"bet_amount\": kelly_bet_amount,\n",
    "            \"bankroll\": kelly_bankroll,\n",
    "            \"update\": kelly_update\n",
    "        })\n",
    "\n",
    "        opportunities.append({\n",
    "            \"match_id\": match.golgg_match_id,\n",
    "            \"date\": date,\n",
    "            \"true_prob1\": true_prob1,\n",
    "            \"true_prob2\": true_prob2,\n",
    "            \"max_odds1\": max_odds1,\n",
    "            \"max_odds2\": max_odds2,\n",
    "            \"EV\": EV*100,\n",
    "            \"update\": update\n",
    "        })\n",
    "    evs.append(EV)\n",
    "   \n",
    "    # print(EV)\n",
    "    \n",
    "print(f\"Average EV: {sum(evs) / len(evs):.4f}\")\n",
    "print(f\"Number of bets with EV > {EV_THRESHOLD}: {sum(ev > EV_THRESHOLD for ev in evs)} out of {len(evs)}\")\n",
    "print(f\"Final bankroll: {bankroll:.2f} (ROI: {(bankroll - 1000) / 1000 * 100:.2f}%) number of bets: {len(bets)}\")\n",
    "print(f\"Final bankroll: {kelly_bankroll:.2f} (ROI: {(kelly_bankroll - 1000) / 1000 * 100:.2f}%) number of bets: {len(bets)}\")\n",
    "\n",
    "bets_0= kelly_bets.copy()\n",
    "# print(f\"Final arbitrage bankroll: {arb_bankroll:.2f} (ROI: {(arb_bankroll - 1000) / 1000 * 100:.2f}%) number of arbitrage bets: {len(arb_opportunities)}\")"
   ]
  },
