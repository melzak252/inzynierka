   "source": [
    "# bookies\n",
    "from collections import defaultdict\n",
    "bookies = [\"efortuna\", \"betfan\", \"sts\", \"lv_bet\", \"superbet\", \"betclic\"]\n",
    "bookies_margines = defaultdict(list)\n",
    "for i, match in df.iterrows():\n",
    "    # calculate average margin\n",
    "    for bookie in bookies:\n",
    "        match_id = match[\"golgg_match_id\"]\n",
    "        odds1 = match[f\"odds1_{bookie}_close\"]\n",
    "        odds2 = match[f\"odds2_{bookie}_close\"]\n",
    "        odds1_open = match[f\"odds1_{bookie}_open\"]\n",
    "        odds2_open = match[f\"odds2_{bookie}_open\"]\n",
    "        if pd.notnull(odds1) and pd.notnull(odds2):\n",
    "            margin = (1 / odds1 + 1 / odds2 - 1) * 100\n",
    "            if margin < 0:\n",
    "                print(f\"Negative margin for {bookie} with odds {odds1} and {odds2}, match id: {match_id}\")\n",
    "            bookies_margines[f\"{bookie}_close\"].append(margin)\n",
    "        if pd.notnull(odds1_open) and pd.notnull(odds2_open):\n",
    "            bookies_margines[f\"{bookie}_open\"].append((1 / odds1_open + 1 / odds2_open - 1) * 100)"
   ]
