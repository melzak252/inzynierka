BETTING_APP_PORT=8501
BETTING_APP_TAX_RATE=0.12
BETTING_APP_MIN_EV=0.05
BETTING_APP_BANKROLL=100.0

# 7200 = 2h. Use 10800 for a safer 3h interval.
BETTING_SCHEDULER_INTERVAL_SECONDS=7200
BETTING_SCHEDULER_RUN_ON_START=1
BETTING_SCHEDULER_BOOKMAKERS=sts,betclic,superbet,efortuna,betfan,totalbet,lebull

# Future Postgres/Timescale target. Current app still defaults to SQLite unless
# we explicitly finish the DB adapter/migration.
POSTGRES_DB=betting
POSTGRES_USER=betting
POSTGRES_PASSWORD=betting_local_password
POSTGRES_PORT=5432
# BETTING_DATABASE_URL=postgresql+psycopg://betting:betting_local_password@timescaledb:5432/betting
