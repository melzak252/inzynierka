# Local development settings.
# Copy this file to `.env` and adjust values if needed.

# Application services
APP_NAME=EnsembleLegends API
ENVIRONMENT=development
SERVER_PORT=8000
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# PostgreSQL connection settings for local development.
POSTGRES_DB=ensemblelegends
POSTGRES_USER=ensemblelegends
POSTGRES_PASSWORD=ensemblelegends_dev_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Local host connection string. Docker Compose injects an internal container URL
# for the `server` service automatically, because containers must use host `postgres`.
DATABASE_URL=postgresql://ensemblelegends:ensemblelegends_dev_password@localhost:5432/ensemblelegends
